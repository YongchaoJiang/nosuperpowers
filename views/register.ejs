<%- include('partials/head', { pageTitle: '注册账号' }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <a href="/" class="back-home">← 返回博客</a>
      <div class="auth-logo">✦</div>
      <h1>注册账号</h1>
      <p>使用邮箱和密码创建一个新账号</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">
        <span>⚠</span> <%= error %>
      </div>
    <% } %>

    <form action="/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">邮箱</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="请输入邮箱"
          autocomplete="email"
          value="<%= draft ? draft.email : '' %>"
          required
          autofocus
        >
      </div>
      <div class="form-group">
        <label for="password">密码</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="至少 8 位"
          autocomplete="new-password"
          required
        >
      </div>
      <button type="submit" class="btn btn-primary btn-full">注册</button>
    </form>

    <p class="auth-footer-note">已有账号？<a href="/admin/login">去登录</a></p>
  </div>
</div>

<%- include('partials/footer') %>
