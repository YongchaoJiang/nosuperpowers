<%- include('../partials/head', { pageTitle: article ? '编辑文章' : '新建文章' }) %>

<!-- Quill CSS -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<link rel="stylesheet" href="/css/editor.css">

<div class="admin-layout">

  <header class="admin-header">
    <div class="admin-header-inner">
      <div class="admin-brand">
        <span class="logo-icon">✦</span>
        <span><%= article ? '编辑文章' : '新建文章' %></span>
      </div>
      <nav class="admin-nav">
        <a href="/admin" class="nav-link">← 返回后台</a>
        <a href="/admin/logout" class="nav-link nav-link-ghost">退出 (<%= adminUser %>)</a>
      </nav>
    </div>
  </header>

  <main class="editor-main">
    <div class="editor-container">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><span>⚠</span> <%= error %></div>
      <% } %>

      <form id="articleForm" action="<%= article ? '/admin/articles/' + article.id : '/admin/articles' %>" method="POST">
        <input type="hidden" name="publishAction" id="publishAction" value="">

        <!-- Title -->
        <div class="editor-title-wrap">
          <input
            type="text"
            name="title"
            id="titleInput"
            class="editor-title-input"
            placeholder="请输入文章标题..."
            value="<%= article ? article.title : '' %>"
            required
          >
        </div>

        <!-- Quill Editor -->
        <div class="quill-wrapper">
          <div id="quillEditor"><%- article ? article.content : '' %></div>
        </div>
        <input type="hidden" name="content" id="contentInput">

        <!-- Action Bar -->
        <div class="editor-actions">
          <div class="editor-actions-left">
            <a href="/admin" class="btn btn-outline">取消</a>
          </div>
          <div class="editor-actions-right">
            <button type="button" class="btn btn-secondary" id="saveDraftBtn">
              保存草稿
            </button>
            <button type="button" class="btn btn-primary" id="publishBtn">
              <% if (article && article.published) { %>
                保存并保持发布
              <% } else { %>
                发布文章
              <% } %>
            </button>
            <% if (article && article.published) { %>
              <button type="button" class="btn btn-warning" id="unpublishBtn">
                取消发布
              </button>
            <% } %>
          </div>
        </div>

      </form>
    </div>
  </main>
</div>

<!-- Quill JS -->
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  // Initialize Quill
  const quill = new Quill('#quillEditor', {
    theme: 'snow',
    placeholder: '开始写作...',
    modules: {
      toolbar: [
        [{ 'header': [1, 2, 3, 4, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
        [{ 'indent': '-1' }, { 'indent': '+1' }],
        [{ 'align': [] }],
        ['blockquote', 'code-block'],
        ['link', 'image'],
        ['clean']
      ]
    }
  });

  // Form submission helper
  function submitForm(publishAction) {
    const title = document.getElementById('titleInput').value.trim();
    if (!title) {
      alert('请填写文章标题');
      document.getElementById('titleInput').focus();
      return;
    }
    const content = quill.root.innerHTML;
    if (quill.getText().trim().length === 0) {
      alert('请填写文章内容');
      return;
    }
    document.getElementById('contentInput').value = content;
    document.getElementById('publishAction').value = publishAction;
    document.getElementById('articleForm').submit();
  }

  document.getElementById('saveDraftBtn').addEventListener('click', () => submitForm('0'));
  document.getElementById('publishBtn').addEventListener('click', () => submitForm('1'));

  const unpublishBtn = document.getElementById('unpublishBtn');
  if (unpublishBtn) {
    unpublishBtn.addEventListener('click', () => submitForm('0'));
  }

  // Auto-save indicator
  let saveTimeout;
  quill.on('text-change', () => {
    clearTimeout(saveTimeout);
    document.getElementById('saveIndicator') && (
      document.getElementById('saveIndicator').textContent = '正在编辑...'
    );
  });
</script>

</body>
</html>
